# Copy this file to .env and fill in the values that apply to your backend.
# Do NOT commit .env to version control.

# --- Together AI (default cloud backend) -----------------------------------
# Obtain a key at https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# --- Generic OpenAI-compatible backend (Fireworks, vLLM server, etc.) -----
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- AWS Bedrock ----------------------------------------------------------
# Use either an IAM profile or explicit access keys.
AWS_PROFILE=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Hugging Face Inference Endpoints -------------------------------------
HF_TOKEN=
HF_ENDPOINT_URL=

# --- Local Ollama ---------------------------------------------------------
OLLAMA_URL=http://localhost:11434

# --- Pipeline overrides ---------------------------------------------------
LLM_MEMORY_EVAL_SEED=42
LLM_MEMORY_EVAL_LOG_LEVEL=INFO
